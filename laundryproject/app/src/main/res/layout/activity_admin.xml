<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F0F4F8">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/adminToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#1a56a0"
        app:title="ADMIN PANEL"
        app:titleTextColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/adminMainScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/adminToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USER INFORMATION"
                android:textColor="#999999"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admin_viewUsersButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="View Users"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#1a56a0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admin_viewMachinesButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="View Machines"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#1a56a0" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TICKETS INFORMATION"
                android:textColor="#999999"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admin_viewTicketsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="View Tickets"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#1a56a0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admin_viewClosedTicketsButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Closed Tickets"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#1a56a0" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUILDING INFORMATION"
                android:textColor="#999999"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admin_editBuildingCodeButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edit Building Code"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#1a56a0" />
            </LinearLayout>

            <TextView
                android:id="@+id/admin_buildingCodesTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="14dp"
                android:text="Building info will appear here"
                android:textColor="#1A1A1A"
                android:textSize="13sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANALYTICS"
                android:textColor="#999999"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/admin_analyticsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Analytics Dashboard"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#1a56a0" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/admin_logoutButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Log Out"
                android:textColor="@android:color/white"
                app:backgroundTint="#888888" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>