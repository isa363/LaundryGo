<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_marginBottom="8dp"
app:cardCornerRadius="12dp"
app:cardElevation="2dp"
app:cardBackgroundColor="#FFFFFF">

<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="14dp">

    <!-- Color accent bar -->
    <View
        android:id="@+id/histAccent"
        android:layout_width="4dp"
        android:layout_height="44dp"
        android:background="#1a56a0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Machine Name -->
    <TextView
        android:id="@+id/histMachineName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Machine 1"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintStart_toEndOf="@id/histAccent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/histCost"
        android:layout_marginStart="12dp"/>

    <!-- Date -->
    <TextView
        android:id="@+id/histDate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Mar 20, 2026 · 3:10 PM"
        android:textSize="11sp"
        android:textColor="#888888"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="@id/histMachineName"
        app:layout_constraintTop_toBottomOf="@id/histMachineName"
        app:layout_constraintEnd_toStartOf="@id/histCost"/>

    <!-- Duration -->
    <TextView
        android:id="@+id/histDuration"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="45 min"
        android:textSize="11sp"
        android:textColor="#888888"
        android:layout_marginTop="1dp"
        app:layout_constraintStart_toStartOf="@id/histMachineName"
        app:layout_constraintTop_toBottomOf="@id/histDate"
        app:layout_constraintEnd_toStartOf="@id/histCost"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Cost -->
    <TextView
        android:id="@+id/histCost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$2.50"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#1a56a0"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>