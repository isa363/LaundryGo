<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tvUserDetailEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="email@example.com"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A56A0" />

    <TextView
        android:id="@+id/tvUserDetailApartment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Apartment: 302"
        android:textSize="14sp"
        android:textColor="#555555" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:background="#E0E0E0" />

    <Button
        android:id="@+id/btnUpdateApartment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Update Apartment"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="#1A56A0"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btnBlockUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Block User"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="#2678A6"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnDeleteUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete User"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:backgroundTint="#E53935"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp" />

</LinearLayout>
