<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FB">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarSubmitTicket"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:title="Submit Ticket"
        app:navigationIcon="@drawable/baseline_arrow_back_24"
        app:navigationIconTint="#000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:elevation="3dp"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create a support ticket"
                    android:textColor="#111111"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Tell us what went wrong and we’ll help you as soon as possible."
                    android:textColor="#6E6E6E"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Subject"
                    android:textColor="#222222"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTicketSubject"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@android:drawable/edit_text"
                    android:hint="Ex: Washer not starting"
                    android:inputType="textCapSentences"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textColor="#111111"
                    android:textColorHint="#8A8A8A" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Category"
                    android:textColor="#222222"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerTicketCategory"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@android:drawable/edit_text"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Description"
                    android:textColor="#222222"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTicketMessage"
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    android:layout_marginTop="8dp"
                    android:background="@android:drawable/edit_text"
                    android:gravity="top|start"
                    android:hint="Describe your issue in detail..."
                    android:inputType="textMultiLine"
                    android:minLines="6"
                    android:padding="12dp"
                    android:textColor="#111111"
                    android:textColorHint="#8A8A8A" />

                <ProgressBar
                    android:id="@+id/progressSubmitTicket"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="18dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnSubmitTicket"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#1976D2"
                    android:text="Submit Ticket"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>