<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- Status circle -->
            <View
                android:id="@+id/cardStatusCircle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/status_circle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- Machine name -->
            <TextView
                android:id="@+id/cardMachineName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Washer 1"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                app:layout_constraintEnd_toStartOf="@id/cardCost"
                app:layout_constraintStart_toEndOf="@id/cardStatusCircle"
                app:layout_constraintTop_toTopOf="@id/cardStatusCircle"/>

            <!-- Machine ID -->
            <TextView
                android:id="@+id/cardMachineId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="2dp"
                android:text="machine_1"
                android:textSize="9sp"
                android:textColor="#BBBBBB"
                android:fontFamily="monospace"
                app:layout_constraintEnd_toStartOf="@id/cardCost"
                app:layout_constraintStart_toEndOf="@id/cardStatusCircle"
                app:layout_constraintTop_toBottomOf="@id/cardMachineName"/>

            <!-- State text -->
            <TextView
                android:id="@+id/cardStateText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="2dp"
                android:text="RUNNING"
                android:textSize="11sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/cardCost"
                app:layout_constraintStart_toEndOf="@id/cardStatusCircle"
                app:layout_constraintTop_toBottomOf="@id/cardMachineId"/>

            <!-- Timer -->
            <TextView
                android:id="@+id/cardTimer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="2dp"
                android:text="00:00:00"
                android:textSize="11sp"
                android:textColor="#FF9800"
                android:visibility="gone"
                app:layout_constraintEnd_toStartOf="@id/cardCost"
                app:layout_constraintStart_toEndOf="@id/cardStatusCircle"
                app:layout_constraintTop_toBottomOf="@id/cardStateText"/>

            <!-- Cost -->
            <TextView
                android:id="@+id/cardCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$2.50"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>
