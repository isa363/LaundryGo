<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Laundryproject">
        <activity
            android:name=".home.AdminAnalyticsActivity"
            android:exported="false" />
        <activity
            android:name=".home.AdminAnalyticsCalculator"
            android:exported="false" />
        <activity
            android:name=".home.HomeActivity"
            android:exported="false" />
        <activity
            android:name=".home.UsageInsightsActivity"
            android:exported="false"
            android:parentActivityName=".home.HistoryActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".home.HistoryActivity" />
        </activity>
        <activity
            android:name=".home.AdminClosedTicketsActivity"
            android:exported="false" />
        <activity
            android:name=".home.ClosedTicketsActivity"
            android:exported="false" />
        <activity
            android:name=".home.TicketChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".home.AdminViewTicketsActivity"
            android:exported="false" />
        <activity
            android:name=".home.MyTicketsActivity"
            android:exported="false" />
        <activity
            android:name=".home.SubmitTicketActivity"
            android:exported="false" />
        <activity
            android:name=".home.AdminViewMachinesActivity"
            android:exported="false" />
        <activity
            android:name=".home.AdminViewUsersActivity"
            android:exported="false" />
        <activity
            android:name=".home.EmailActionHandlerActivity"
            android:exported="true">
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="laundryproject-ecf27.firebaseapp.com"
                    android:pathPrefix="/__/auth/links"
                    android:scheme="https" />
            </intent-filter>
        </activity> <!-- Starting screens -->
        <!-- Auth screens -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".auth.RegisterActivity"
            android:exported="false" />
        <activity
            android:name=".auth.ForgotPasswordActivity"
            android:exported="false" /> <!-- Main app screens -->
        <activity
            android:name=".home.MainActivity"
            android:exported="false" />
        <activity
            android:name=".home.AdminActivity"
            android:exported="false" />
        <activity
            android:name=".home.MachineDetailActivity"
            android:exported="false"
            android:parentActivityName=".home.MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".home.MainActivity" />
        </activity>
        <activity
            android:name=".home.HistoryActivity"
            android:exported="false"
            android:parentActivityName=".home.MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".home.MainActivity" />
        </activity>
        <activity
            android:name=".home.ProfileActivity"
            android:exported="false"
            android:parentActivityName=".home.MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".home.MainActivity" />
        </activity>
    </application>

</manifest>